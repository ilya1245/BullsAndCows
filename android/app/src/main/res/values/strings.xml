    <!-- Help dialog -->
    <string name="help_title">Game Rules</string>
    <string name="help_intro">The computer thinks of a number with unique digits and no leading zero. Default: 4 digits (3–6 in settings). Your goal is to guess it.</string>
    <string name="help_how_to_play_title">How to play</string>
    <string name="help_how_to_play">You suggest a number and the computer tells you the result:</string>
    <string name="help_bull">🐂 Bull — correct digit in the correct position.</string>
    <string name="help_cow">🐄 Cow — correct digit in the wrong position.</string>
    <string name="help_win">To win, you need as many bulls as the number of digits.</string>
    <string name="help_example_title">Example</string>
    <string name="help_example">Computer thought: 8203\nYour guess: 7235\nResult: 1 bull (digit «2» is in place), 1 cow (digit «3» is present but wrong position).</string>
    <string name="help_trick_title">Hint</string>
    <string name="help_trick">Type «number» instead of a digit from move 5 to see the answer — but it counts as a loss!</string>
    <string name="help_types_title">Game types</string>
    <string name="help_type_1">Computer thinks — you guess.</string>
    <string name="help_type_2">You think — computer guesses, you tell it bulls and cows.</string>
    <string name="help_type_3">Both think — both guess in turns. The one who guesses first wins (or both, if «Continue» is on).</string>
